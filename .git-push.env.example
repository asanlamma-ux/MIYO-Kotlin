# Copy this file to .git-push.env and fill in the values.
# .git-push.env is intentionally ignored by git.

GITHUB_USERNAME="your-github-username"
GITHUB_PAT="github_pat_or_classic_pat_here"
GMAIL="your-email@gmail.com"

# Optional. Defaults to origin and the current branch.
GIT_REMOTE="origin"
GIT_BRANCH=""
